#include <cs50.h>
#include <stdio.h>

int main(void)
{
    int n;
    do { n = get_int("Height: "); } while (n < 1 || n > 8);
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n - i - 1; j++) printf(" ");
        for (int k = 0; k < i + 1; k++) printf("#");
        printf("\n");
    }
}
#include <cs50.h>
#include <stdio.h>

int main(void)
{
    int n;
    do { n = get_int("Change owed: "); } while (n < 0);
    int coins = 0;
    int denoms[] = {25, 10, 5, 1};
    for (int i = 0; i < 4; i++) {
        coins += n / denoms[i];
        n %= denoms[i];
    }
    printf("%i\n", coins);
}
