-- Week 8 SQL solutions

-- 01 basics
SELECT * FROM movies;
SELECT title FROM movies;
SELECT title, year FROM movies ORDER BY year DESC;
SELECT * FROM movies LIMIT 10;

-- 02 filtering
SELECT * FROM movies WHERE year >= 2000;
SELECT * FROM movies WHERE rating >= 8.0;
SELECT * FROM movies WHERE title LIKE '%star%';
SELECT * FROM movies WHERE year BETWEEN 1990 AND 1999;

-- 03 sorting
SELECT * FROM movies ORDER BY rating DESC;
SELECT * FROM movies ORDER BY year ASC, title ASC;
SELECT * FROM movies ORDER BY rating DESC LIMIT 5;

-- 04 aggregates
SELECT COUNT(*) FROM movies;
SELECT AVG(rating) FROM movies;
SELECT year, COUNT(*) FROM movies GROUP BY year ORDER BY year;
SELECT genre, AVG(rating) FROM movies GROUP BY genre ORDER BY AVG(rating) DESC;

-- 05 joins
SELECT students.name, courses.title
FROM enrollments
JOIN students ON students.id = enrollments.student_id
JOIN courses ON courses.id = enrollments.course_id;

SELECT books.title, authors.name
FROM books
JOIN authors ON authors.id = books.author_id;

-- 06 subqueries
SELECT title FROM movies WHERE rating > (SELECT AVG(rating) FROM movies);
SELECT name FROM students WHERE id IN (
  SELECT student_id FROM enrollments GROUP BY student_id HAVING COUNT(*) >= 2
);

-- 07 schema design
CREATE TABLE users (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  username TEXT NOT NULL UNIQUE,
  email TEXT NOT NULL UNIQUE
);

CREATE TABLE posts (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  user_id INTEGER NOT NULL,
  title TEXT NOT NULL,
  body TEXT NOT NULL,
  created_at TEXT DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (user_id) REFERENCES users(id)
);

-- 08 indexes
CREATE INDEX idx_movies_title ON movies(title);
CREATE INDEX idx_movies_year ON movies(year);
