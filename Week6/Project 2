import random

def main():
    secret = random.randint(1, 100)
    attempts = 0
    print("Guess the number from 1 to 100.")
    while True:
        try:
            guess = int(input("Guess: "))
            attempts += 1
            if guess < secret:
                print("Too low.")
            elif guess > secret:
                print("Too high.")
            else:
                print(f"Correct! You guessed it in {attempts} attempts.")
                break
        except ValueError:
            print("Enter a whole number.")

if __name__ == "__main__":
    main()
