import csv

INPUT = "../week1/favorites.csv"
OUTPUT = "favorites_clean.csv"

def clean(value):
    return " ".join((value or "").strip().split())

def main():
    seen = set()
    cleaned_rows = []
    with open(INPUT, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        fieldnames = reader.fieldnames or []
        for row in reader:
            cleaned = {key: clean(value) for key, value in row.items()}
            marker = tuple(cleaned.get(k, "") for k in fieldnames)
            if marker not in seen and any(cleaned.values()):
                seen.add(marker)
                cleaned_rows.append(cleaned)

    with open(OUTPUT, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(cleaned_rows)

    print(f"Saved {len(cleaned_rows)} cleaned rows to {OUTPUT}")

if __name__ == "__main__":
    main()
